<?xml version="1.0" encoding="utf-8"?>

<!--suppress ALL -->

<resources>

    <!-- Base -->

    <style name="Theme.Main" parent="@style/Theme.AppCompat.Light.NoActionBar">
        <item name="colorAccent">@color/primary</item>
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/black</item>
        <item name="android:textColorPrimary">@color/title</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:windowAnimationStyle">@style/Anim.Main</item>
        <item name="android:colorBackgroundCacheHint">@color/background</item>
    </style>

    <style name="Anim.Main" parent="@android:style/Animation">
        <item name="android:activityOpenExitAnimation">@anim/slide_left_out</item>
        <item name="android:activityOpenEnterAnimation">@anim/slide_right_in</item>
        <item name="android:activityCloseEnterAnimation">@anim/slide_left_in</item>
        <item name="android:activityCloseExitAnimation">@anim/slide_right_out</item>
    </style>

    <style name="Theme.Load" parent="Theme.Main">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@color/transparent</item>
        <item name="android:colorBackgroundCacheHint">@color/transparent</item>
    </style>

    <!-- View -->

    <style name="View" />

    <style name="View.Line">
        <item name="android:layout_height">1px</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:background">@color/background</item>
    </style>

    <style name="View.Horizontal">
        <item name="android:layout_width">1px</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:background">@color/background</item>
    </style>

    <!-- Layout -->

    <style name="Layout" />

    <style name="Layout.Main">
        <item name="android:orientation">vertical</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
    </style>

    <style name="Layout.Tool">
        <item name="android:paddingLeft">16dip</item>
        <item name="android:paddingRight">16dip</item>
        <item name="android:layout_height">48dip</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:background">@drawable/selector_color_white</item>
    </style>

    <style name="Layout.Wrap">
        <item name="android:orientation">vertical</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <!-- Toolbar -->

    <style name="Toolbar" />

    <style name="Toolbar.Main">
        <item name="android:layout_height">48dip</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:background">@color/whiteSub</item>
        <item name="contentInsetStartWithNavigation">0dip</item>
    </style>

    <style name="TextView" />

    <style name="TextView.Title">
        <item name="android:textSize">16sp</item>
        <item name="android:ellipsize">end</item>
        <item name="android:layout_height">48dip</item>
        <item name="android:drawablePadding">8dip</item>
        <item name="android:layout_gravity">center</item>
        <item name="android:textColor">@color/title</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:layout_width">wrap_content</item>
    </style>

    <style name="TextView.Small">
        <item name="android:textSize">12sp</item>
        <item name="android:ellipsize">end</item>
        <item name="android:drawablePadding">8dip</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:textColor">@color/greyAdd</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="TextView.Smalls">
        <item name="android:textSize">10sp</item>
        <item name="android:ellipsize">end</item>
        <item name="android:drawablePadding">8dip</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:textColor">@color/greyAdd</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="TextView.Button">
        <item name="android:textSize">14sp</item>
        <item name="android:gravity">center</item>
        <item name="android:layout_margin">16dip</item>
        <item name="android:layout_height">40dip</item>
        <item name="android:drawablePadding">8dip</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:background">@drawable/selector_border_primary</item>
    </style>

    <style name="TextView.Normal">
        <item name="android:textSize">14sp</item>
        <item name="android:ellipsize">end</item>
        <item name="android:drawablePadding">8dip</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:textColor">@color/greyAdd</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
    </style>


    <style name="EditText" />

    <style name="EditText.Line">
        <item name="android:maxLines">1</item>
        <item name="android:textSize">14sp</item>
        <item name="android:inputType">text</item>
        <item name="android:hint">请输入内容</item>
        <item name="android:paddingLeft">8dip</item>
        <item name="android:paddingRight">8dip</item>
        <item name="android:layout_height">48dip</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:textColorHint">@color/greySub</item>
        <item name="android:background">@color/transparent</item>
    </style>

    <style name="EditText.Username">
        <item name="android:maxLines">1</item>
        <item name="android:textSize">14sp</item>
        <item name="android:inputType">text</item>
        <item name="android:hint">请输入账户名</item>
        <item name="android:paddingLeft">12dip</item>
        <item name="android:paddingRight">12dip</item>
        <item name="android:layout_height">48dip</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:textColorHint">@color/greySub</item>
        <item name="android:background">@color/transparent</item>
    </style>

    <style name="EditText.Password">
        <item name="android:maxLines">1</item>
        <item name="android:textSize">14sp</item>
        <item name="android:paddingLeft">12dip</item>
        <item name="android:hint">请输入账户密码</item>
        <item name="android:paddingRight">12dip</item>
        <item name="android:layout_height">48dip</item>
        <item name="android:inputType">textPassword</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:textColorHint">@color/greySub</item>
        <item name="android:background">@color/transparent</item>
    </style>

    <!-- ImageView -->

    <style name="ImageView" />

    <style name="ImageView.Main">
        <item name="android:scaleType">fitXY</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
    </style>

</resources>
